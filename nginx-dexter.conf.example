# Dexter Web UI - Nginx 反代示例（与现有 80 端口共存）
# 用法：复制到 /etc/nginx/conf.d/dexter.conf 并修改 server_name，然后 sudo nginx -t && sudo systemctl reload nginx
# 将 server_name 改为你的 Dexter 域名（如 dexter.decentglobal.com），并在 Route53 添加 A 记录指向本机

server {
    listen 80;
    server_name dexter.decentglobal.com;   # 改成你的 Dexter 域名

    client_max_body_size 10M;

    location / {
        proxy_pass http://127.0.0.1:3002/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # SSE / EventSource 长连接（聊天流）
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
        proxy_set_header Connection '';
        chunked_transfer_encoding off;
    }

    location ~ /\.(?!well-known).* {
        deny all;
    }
}
